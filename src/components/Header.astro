---
const nav = [
  {
    href: "/",
    label: "首页",
    paths: [
      "M3 10.8 12 3.6l9 7.2",
      "M5.5 9.7V20h13V9.7",
      "M9.5 20v-6h5v6"
    ]
  },
  {
    href: "/blog/",
    label: "文章",
    paths: [
      "M5 4h14v16H5z",
      "M8 8h8",
      "M8 12h8",
      "M8 16h5"
    ]
  },
  {
    href: "/about/",
    label: "关于",
    paths: [
      "M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18z",
      "M12 11v6",
      "M12 7.4v.1"
    ]
  },
  {
    href: "https://github.com/RainPot",
    label: "GitHub",
    external: true,
    paths: [
      "M7 7.5 4.5 10 7 12.5",
      "M17 7.5 19.5 10 17 12.5",
      "M14 5.5 10 18.5"
    ]
  }
];
const link = (href: string, external?: boolean) => external ? href : `${import.meta.env.BASE_URL}${href.replace(/^\//, "")}`;
const normalizePath = (path: string) => path.endsWith("/") ? path : `${path}/`;
const currentPath = normalizePath(Astro.url.pathname);
const isActive = (href: string, external?: boolean) => {
  if (external) return false;

  const target = normalizePath(link(href));
  return href === "/" ? currentPath === target : currentPath.startsWith(target);
};
---

<header class="site-header" id="top">
  <a class="brand" href={link("/")} aria-label="RainPot 首页">
    <span class="brand-mark">~/</span>
    <span>
      <strong>RainPot</strong>
      <small>dev notes</small>
    </span>
  </a>
  <nav class="nav-links" aria-label="主导航">
    {nav.map((item) => (
      <a
        class:list={{ "is-active": isActive(item.href, item.external) }}
        href={link(item.href, item.external)}
        target={item.external ? "_blank" : undefined}
        rel={item.external ? "noreferrer" : undefined}
        aria-label={item.label}
        aria-current={isActive(item.href, item.external) ? "page" : undefined}
      >
        <span class="nav-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            {item.paths.map((path) => <path d={path} />)}
          </svg>
        </span>
        <span class="nav-label">{item.label}</span>
        <span class="nav-tooltip" role="tooltip">{item.label}</span>
      </a>
    ))}
  </nav>
</header>

<script>
  import "../scripts/header";
</script>
