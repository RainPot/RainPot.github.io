---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPostSlug, getPublishedPosts } from "../lib/blog";

const posts = getPublishedPosts(await getCollection("blog"));
const latestPost = posts[0];
const link = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\//, "")}`;
---

<BaseLayout>
  <main id="main-content" class="home-main">
    <section class="hero code-hero">
      <div class="hero-copy">
        <p class="eyebrow"><span class="dot"></span> ~/rainpot.dev</p>
        <h1>Simplicity is the ultimate sophistication.</h1>
        <div class="hero-actions">
          {latestPost && <a class="button primary" href={link(`/blog/${getPostSlug(latestPost)}/`)}>读最新笔记</a>}
          <a class="button ghost" href={link("/blog/")}>文章归档</a>
        </div>
      </div>
      <div class="terminal-card" aria-label="RainPot 代码摘要">
        <div class="terminal-bar">
          <span></span><span></span><span></span>
          <b>notes.ts</b>
        </div>
        <pre><code><span class="muted">const principle =</span> ["simple", "pure", "real"];
<span class="muted">const latest =</span> await read("latest-note");
ship(notes.filter(Boolean));</code></pre>
      </div>
    </section>
  </main>
</BaseLayout>
