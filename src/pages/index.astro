---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <main id="main-content">
    <section class="solar-system-section" id="articles" aria-label="当前太阳系">
      <div class="solar-system" id="solar-system" data-solar-system>
        <div class="solar-stage" data-solar-stage></div>
        <div class="solar-panel">
          <p class="eyebrow"><span class="dot"></span> solar clock</p>
          <time class="solar-time" data-solar-time></time>
          <ol class="solar-readout" aria-label="行星当前位置">
            <li data-planet-row="mercury"><span>水星</span><b>0°</b></li>
            <li data-planet-row="venus"><span>金星</span><b>0°</b></li>
            <li data-planet-row="earth"><span>地球</span><b>0°</b></li>
            <li data-planet-row="mars"><span>火星</span><b>0°</b></li>
            <li data-planet-row="jupiter"><span>木星</span><b>0°</b></li>
            <li data-planet-row="saturn"><span>土星</span><b>0°</b></li>
            <li data-planet-row="uranus"><span>天王星</span><b>0°</b></li>
            <li data-planet-row="neptune"><span>海王星</span><b>0°</b></li>
          </ol>
        </div>
      </div>
    </section>
  </main>
  <script>
    import "../scripts/solar-system";
  </script>
</BaseLayout>
