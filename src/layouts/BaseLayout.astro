---
import CosmicBackground from "../components/CosmicBackground.astro";
import Header from "../components/Header.astro";
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
};

const {
  title = "RainPot",
  description = "RainPot 的宇宙极客代码笔记：AI Agent、工程实践、计算机视觉与长期学习。"
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#000000" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=M+PLUS+1+Code:wght@400;500;600;700&family=M+PLUS+Rounded+1c:wght@400;500;700&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600;6..72,700&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <CosmicBackground />
    <div class="page-shell">
      <Header />
      <slot />
      <footer class="footer">
        <div class="footer-meta">
          <span>Copyright © 2026 RainPot</span>
          <a href="#top">回到顶部</a>
        </div>
      </footer>
    </div>
  </body>
</html>
