<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="CubeSandbox 创建链路">
    <mxGraphModel dx="1680" dy="920" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="920" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="CubeSandbox 创建沙箱链路" style="text;html=1;strokeColor=none;fillColor=none;fontSize=30;fontStyle=1;fontColor=#1f2937;align=left;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="60" y="40" width="560" height="50" as="geometry" />
        </mxCell>
        <mxCell id="note" value="从 E2B 兼容 REST 请求，到调度、rootfs 克隆、tap 网络、MicroVM 启动，再把代理和生命周期状态写回 Redis。" style="text;html=1;strokeColor=none;fillColor=none;fontSize=20;fontColor=#4b5563;align=left;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="60" y="102" width="1180" height="38" as="geometry" />
        </mxCell>
        <mxCell id="client" value="Client / E2B SDK&#xa;POST /sandboxes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#111827;fontSize=20;fontStyle=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="190" width="220" height="96" as="geometry" />
        </mxCell>
        <mxCell id="api" value="CubeAPI&#xa;校验 env/lifecycle/network&#xa;组装 CreateSandboxRequest" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#111827;fontSize=18;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="350" y="170" width="260" height="136" as="geometry" />
        </mxCell>
        <mxCell id="master" value="CubeMaster&#xa;调度节点&#xa;失败重试 / 熔断坏节点" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontColor=#111827;fontSize=18;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="690" y="170" width="260" height="136" as="geometry" />
        </mxCell>
        <mxCell id="cubelet" value="Cubelet&#xa;RunCubeSandbox&#xa;默认 tap 网络" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#111827;fontSize=18;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1030" y="170" width="250" height="136" as="geometry" />
        </mxCell>
        <mxCell id="cow" value="CubeCoW&#xa;模板 rootfs&#xa;reflink O(1) 克隆" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfccb;strokeColor=#65a30d;fontColor=#111827;fontSize=18;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1030" y="410" width="250" height="118" as="geometry" />
