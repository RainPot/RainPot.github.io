<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="CubeSandbox 出网治理">
    <mxGraphModel dx="1680" dy="920" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="920" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="CubeVS + CubeEgress 出网治理路径" style="text;html=1;strokeColor=none;fillColor=none;fontSize=30;fontStyle=1;fontColor=#1f2937;align=left;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="60" y="40" width="740" height="50" as="geometry" />
        </mxCell>
        <mxCell id="note" value="CubeVS 在 TC ingress 上先做逐沙箱 L3/L4 策略和 NAT；命中 L7 标记的 80/443 流量再进入 CubeEgress 做域名、注入和审计。" style="text;html=1;strokeColor=none;fillColor=none;fontSize=20;fontColor=#4b5563;align=left;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="60" y="102" width="1320" height="38" as="geometry" />
        </mxCell>
        <mxCell id="sandbox" value="MicroVM Sandbox&#xa;untrusted code" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#111827;fontSize=20;fontStyle=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="210" width="230" height="116" as="geometry" />
        </mxCell>
        <mxCell id="tap" value="TAP 设备&#xa;ifindex + sandbox_ip" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#111827;fontSize=18;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="360" y="210" width="220" height="116" as="geometry" />
        </mxCell>
        <mxCell id="fromcube" value="from_cube BPF&#xa;SNAT / ARP proxy&#xa;check_net_policy()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ccfbf1;strokeColor=#0f766e;fontColor=#111827;fontSize=18;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="650" y="190" width="250" height="156" as="geometry" />
        </mxCell>
        <mxCell id="policy" value="策略优先级&#xa;allow_out_v2&#xa;&gt; deny_out&#xa;&gt; default allow" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontColor=#111827;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="980" y="170" width="230" height="196" as="geometry" />
        </mxCell>
        <mxCell id="drop" value="deny 命中&#xa;TCP reset / drop" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontColor=#111827;fontSize=18;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1320" y="145" width="230" height="96" as="geometry" />
        </mxCell>
        <mxCell id="nat" value="L3/L4 通过&#xa;do_tcp_nat / UDP NAT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#111827;fontSize=18;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1320" y="285" width="230" height="96" as="geometry" />
        </mxCell>
        <mxCell id="l7flag" value="L7_REQUIRED&#xa;TCP 80 / 443" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontColor=#111827;fontSize=18;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="980" y="500" width="230" height="96" as="geometry" />
        </mxCell>
        <mxCell id="tproxy" value="cube-dev / TPROXY&#xa;转入本机 OpenResty" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#8b5cf6;fontColor=#111827;fontSize=18;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="650" y="490" width="250" height="116" as="geometry" />
        </mxCell>
        <mxCell id="egress" value="CubeEgress&#xa;first-match-wins&#xa;默认拒绝 / 失败关闭" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#ea580c;fontColor=#111827;fontSize=18;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="360" y="480" width="220" height="136" as="geometry" />
