<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="30.0.4">
  <diagram name="写入链路">
    <mxGraphModel dx="1200" dy="1300" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="1300" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Codex Memory 写入链路：两阶段异步整理" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=38;fontStyle=1;fontColor=#102A43;" vertex="1" parent="1">
          <mxGeometry x="40" y="16" width="1160" height="46" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="新会话启动时后台触发；Phase 1 抽取单个会话、可并发，Phase 2 合并全局工作区、必须串行加锁" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=21;fontColor=#486581;" vertex="1" parent="1">
          <mxGeometry x="40" y="62" width="1160" height="32" as="geometry" />
        </mxCell>

        <!-- Lane 1: 启动与准入 -->
        <mxCell id="lane1" value="① 启动与准入（周二 08:00，新会话 B 启动）" style="swimlane;startSize=48;rounded=1;html=1;fillColor=#F0F7FF;swimlaneFillColor=#FFFFFF;strokeColor=#9FB3C8;strokeWidth=2;fontColor=#243B53;fontSize=23;fontStyle=1;container=1;collapsible=0;horizontal=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="112" width="1160" height="220" as="geometry" />
        </mxCell>
        <mxCell id="n-start" value="&lt;b&gt;新会话启动&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:19px&quot;&gt;root session · 非 ephemeral&lt;br&gt;非 sub-agent&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D9EAFD;strokeColor=#486FA8;strokeWidth=3;fontColor=#102A43;fontSize=24;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="lane1">
          <mxGeometry x="70" y="66" width="300" height="138" as="geometry" />
        </mxCell>
        <mxCell id="n-gate" value="&lt;b&gt;资格与配额检查&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:18px&quot;&gt;generate_memories 开启&lt;br&gt;rate limit 剩余 ≥ 25%&lt;br&gt;&lt;i&gt;不满足则整条链路跳过&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D9EAFD;strokeColor=#486FA8;strokeWidth=3;fontColor=#102A43;fontSize=24;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="lane1">
          <mxGeometry x="430" y="60" width="300" height="150" as="geometry" />
        </mxCell>
        <mxCell id="n-prune" value="&lt;b&gt;phase1::prune&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:19px&quot;&gt;清理过期 / 失效候选&lt;br&gt;异步任务，不阻塞当前对话&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D9EAFD;strokeColor=#486FA8;strokeWidth=3;fontColor=#102A43;fontSize=24;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="lane1">
          <mxGeometry x="790" y="66" width="300" height="138" as="geometry" />
        </mxCell>
        <mxCell id="e-start-gate" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#486581;strokeWidth=3;endArrow=block;endFill=1;" edge="1" parent="lane1" source="n-start" target="n-gate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-gate-prune" value="通过" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#486581;strokeWidth=3;endArrow=block;endFill=1;fontSize=17;fontColor=#334E68;labelBackgroundColor=#FFFFFF;" edge="1" parent="lane1" source="n-gate" target="n-prune">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Lane 2: Phase 1 -->
        <mxCell id="lane2" value="② Phase 1：单会话抽取（并发，每次最多认领 2 个 rollout）" style="swimlane;startSize=48;rounded=1;html=1;fillColor=#F8F4FF;swimlaneFillColor=#FFFFFF;strokeColor=#B8A9D9;strokeWidth=2;fontColor=#3F3D56;fontSize=23;fontStyle=1;container=1;collapsible=0;horizontal=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="352" width="1160" height="260" as="geometry" />
        </mxCell>
        <mxCell id="n-select" value="&lt;b&gt;筛选 rollout&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:18px&quot;&gt;10 天内 · idle ≥ 6 小时&lt;br&gt;memory_mode=enabled&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8E0F5;strokeColor=#7B68A6;strokeWidth=3;fontColor=#2D2550;fontSize=22;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="lane2">
          <mxGeometry x="50" y="80" width="250" height="140" as="geometry" />
        </mxCell>
        <mxCell id="n-filter" value="&lt;b&gt;输入净化&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:18px&quot;&gt;过滤 developer message&lt;br&gt;过滤 AGENTS.md / &amp;lt;skill&amp;gt; 片段&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8E0F5;strokeColor=#7B68A6;strokeWidth=3;fontColor=#2D2550;fontSize=22;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="lane2">
          <mxGeometry x="340" y="80" width="250" height="140" as="geometry" />
        </mxCell>
        <mxCell id="n-extract" value="&lt;b&gt;抽取模型&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:18px&quot;&gt;严格 JSON：raw_memory ·&lt;br&gt;rollout_summary · rollout_slug&lt;br&gt;+ secret redaction&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8E0F5;strokeColor=#7B68A6;strokeWidth=3;fontColor=#2D2550;fontSize=22;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="lane2">
          <mxGeometry x="630" y="80" width="250" height="140" as="geometry" />
        </mxCell>
        <mxCell id="n-pool" value="&lt;b&gt;候选记忆池&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:18px&quot;&gt;SQLite stage1_outputs&lt;br&gt;usage_count · last_usage&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8E0F5;strokeColor=#7B68A6;strokeWidth=3;fontColor=#2D2550;fontSize=22;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="lane2">
          <mxGeometry x="920" y="80" width="200" height="140" as="geometry" />
        </mxCell>
        <mxCell id="e-select-filter" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#6B5B95;strokeWidth=3;endArrow=block;endFill=1;" edge="1" parent="lane2" source="n-select" target="n-filter">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-filter-extract" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#6B5B95;strokeWidth=3;endArrow=block;endFill=1;" edge="1" parent="lane2" source="n-filter" target="n-extract">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-extract-pool" value="upsert" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#6B5B95;strokeWidth=3;endArrow=block;endFill=1;fontSize=17;fontColor=#4C3F73;labelBackgroundColor=#FFFFFF;" edge="1" parent="lane2" source="n-extract" target="n-pool">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Lane 3: Phase 2 -->
        <mxCell id="lane3" value="③ Phase 2：全局合并（单例锁，串行）" style="swimlane;startSize=48;rounded=1;html=1;fillColor=#FFF8E8;swimlaneFillColor=#FFFFFF;strokeColor=#D9B45B;strokeWidth=2;fontColor=#5D4600;fontSize=23;fontStyle=1;container=1;collapsible=0;horizontal=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="632" width="1160" height="600" as="geometry" />
        </mxCell>

        <mxCell id="n-lock" value="&lt;b&gt;单例锁&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:18px&quot;&gt;memory_consolidate_global&lt;br&gt;防止多进程并发改写&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF0C2;strokeColor=#C69214;strokeWidth=3;fontColor=#5D4600;fontSize=22;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="lane3">
          <mxGeometry x="60" y="76" width="290" height="130" as="geometry" />
        </mxCell>
        <mxCell id="n-topn" value="&lt;b&gt;选 top-N 候选&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:18px&quot;&gt;usage_count DESC&lt;br&gt;30 天未用则淘汰&lt;br&gt;默认 ≤256，硬上限 4096&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF0C2;strokeColor=#C69214;strokeWidth=3;fontColor=#5D4600;fontSize=22;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="lane3">
          <mxGeometry x="420" y="76" width="290" height="130" as="geometry" />
        </mxCell>
        <mxCell id="n-materialize" value="&lt;b&gt;物化为文件&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:18px&quot;&gt;raw_memories.md&lt;br&gt;rollout_summaries/&amp;lt;slug&amp;gt;.md&lt;br&gt;删除不再入选的旧文件&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF0C2;strokeColor=#C69214;strokeWidth=3;fontColor=#5D4600;fontSize=22;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="lane3">
          <mxGeometry x="780" y="76" width="320" height="130" as="geometry" />
        </mxCell>
        <mxCell id="e-lock-topn" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#A87400;strokeWidth=3;endArrow=block;endFill=1;" edge="1" parent="lane3" source="n-lock" target="n-topn">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-topn-mat" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#A87400;strokeWidth=3;endArrow=block;endFill=1;" edge="1" parent="lane3" source="n-topn" target="n-materialize">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="n-diff" value="工作区&lt;br&gt;有变化？&lt;br&gt;&lt;font style=&quot;font-size:15px&quot;&gt;(git baseline diff)&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF0C2;strokeColor=#C69214;strokeWidth=3;fontColor=#5D4600;fontSize=20;align=center;verticalAlign=middle;" vertex="1" parent="lane3">
          <mxGeometry x="100" y="270" width="210" height="160" as="geometry" />
        </mxCell>
        <mxCell id="n-skip" value="&lt;b&gt;跳过本轮&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:17px&quot;&gt;不启动 consolidation agent&lt;br&gt;不浪费一次模型调用&lt;/font&gt;" style="rounded=1;dashed=1;whiteSpace=wrap;html=1;fillColor=#FBF3DA;strokeColor=#C69214;strokeWidth=2;fontColor=#8A6D00;fontSize=19;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="lane3">
          <mxGeometry x="60" y="470" width="290" height="100" as="geometry" />
        </mxCell>
        <mxCell id="n-sandbox" value="&lt;b&gt;consolidation agent（受限沙箱）&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:17px&quot;&gt;cwd=memory root · 自身 ephemeral&lt;br&gt;自身 generate/use_memories=false&lt;br&gt;关闭 MCP/Apps/Plugins · approvals=never&lt;br&gt;无网络 · 只允许写 memory root&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE3E3;strokeColor=#C0392B;strokeWidth=3;fontColor=#7A1F14;fontSize=20;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="lane3">
          <mxGeometry x="400" y="260" width="360" height="180" as="geometry" />
        </mxCell>
        <mxCell id="n-output" value="&lt;b&gt;产出正式文件&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:18px&quot;&gt;MEMORY.md&lt;br&gt;memory_summary.md&lt;br&gt;skills/*&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D9F2E3;strokeColor=#3F9964;strokeWidth=3;fontColor=#164C31;fontSize=22;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="lane3">
          <mxGeometry x="850" y="270" width="250" height="160" as="geometry" />
        </mxCell>

        <mxCell id="e-mat-diff" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#A87400;strokeWidth=3;endArrow=block;endFill=1;" edge="1" parent="lane3" source="n-materialize" target="n-diff">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="940" y="240" />
              <mxPoint x="205" y="240" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e-diff-skip" value="无变化" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#A87400;strokeWidth=3;endArrow=block;endFill=1;fontSize=17;fontColor=#7A5700;labelBackgroundColor=#FFFFFF;" edge="1" parent="lane3" source="n-diff" target="n-skip">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-diff-sandbox" value="有变化" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#A87400;strokeWidth=3;endArrow=block;endFill=1;fontSize=17;fontColor=#7A5700;labelBackgroundColor=#FFFFFF;" edge="1" parent="lane3" source="n-diff" target="n-sandbox">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-sandbox-output" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#A87400;strokeWidth=3;endArrow=block;endFill=1;" edge="1" parent="lane3" source="n-sandbox" target="n-output">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="n-validate" value="&lt;b&gt;验收 &amp;amp; 重置基线&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:17px&quot;&gt;MEMORY.md 必须存在&lt;br&gt;summary 首行必须是 &amp;quot;v1&amp;quot;&lt;br&gt;通过 → reset baseline&lt;br&gt;标记 selected_for_phase2=1&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D9F2E3;strokeColor=#3F9964;strokeWidth=3;fontColor=#164C31;fontSize=19;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="lane3">
          <mxGeometry x="850" y="470" width="250" height="100" as="geometry" />
        </mxCell>
        <mxCell id="e-output-validate" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#3F9964;strokeWidth=3;endArrow=block;endFill=1;" edge="1" parent="lane3" source="n-output" target="n-validate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="note" value="产出的 MEMORY.md / memory_summary.md / skills/* 会在下一次新会话启动时被读取链路使用（见另一张图）" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=18;fontColor=#627D98;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="1246" width="1160" height="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
